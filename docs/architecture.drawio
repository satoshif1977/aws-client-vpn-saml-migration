<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.6.1 Chrome/142.0.7444.265 Electron/39.8.0 Safari/537.36" version="29.6.1">
  <diagram id="vpn-saml-migration" name="VPN Migration Architecture">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== TITLE ===== -->
        <mxCell id="title" parent="1"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#232F3E;"
          value="AWS Client VPN 移行アーキテクチャ（SAML 2.0 認証）" vertex="1">
          <mxGeometry height="40" width="1560" x="20" y="10" as="geometry" />
        </mxCell>

        <mxCell id="subtitle" parent="1"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontColor=#666666;"
          value="Cisco VPN (ASA5512) EOL 2026年3月 → AWS Client VPN + OneLogin (SAML 2.0) + MFA  |  ap-northeast-1  |  対象: 約115名" vertex="1">
          <mxGeometry height="22" width="1560" x="20" y="48" as="geometry" />
        </mxCell>

        <!-- ===== BEFORE PANEL ===== -->
        <mxCell id="before-panel" parent="1"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8F9F9;strokeColor=#95A5A6;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#555555;arcSize=2;spacingTop=8;spacingLeft=10;"
          value="【移行前】Cisco VPN + AD 認証" vertex="1">
          <mxGeometry height="720" width="510" x="20" y="75" as="geometry" />
        </mxCell>

        <!-- Before: User -->
        <mxCell id="b-user" parent="1"
          style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=1;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.user;"
          value="ユーザー" vertex="1">
          <mxGeometry height="60" width="60" x="55" y="285" as="geometry" />
        </mxCell>

        <!-- Before: Cisco VPN box -->
        <mxCell id="b-cisco" parent="1"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECF0F1;strokeColor=#7F8C8D;fontSize=11;fontStyle=1;verticalAlign=middle;"
          value="Cisco VPN&#xa;(ASA5512)&#xa;&#xa;EOL: 2026年3月" vertex="1">
          <mxGeometry height="90" width="120" x="185" y="270" as="geometry" />
        </mxCell>

        <!-- Before: AD box -->
        <mxCell id="b-ad" parent="1"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;fontStyle=1;verticalAlign=middle;"
          value="Active Directory&#xa;&#xa;SID ベース認証" vertex="1">
          <mxGeometry height="90" width="120" x="355" y="270" as="geometry" />
        </mxCell>

        <!-- Before: Internal systems -->
        <mxCell id="b-internal" parent="1"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;fontStyle=1;verticalAlign=middle;"
          value="社内システム&#xa;（FENICS 網）" vertex="1">
          <mxGeometry height="80" width="120" x="355" y="480" as="geometry" />
        </mxCell>

        <!-- Before: SID note -->
        <mxCell id="b-note" parent="1"
          style="sketch=0;outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=10;fontStyle=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_note;strokeColor=#AAB7B8;fillColor=#F2F3F4;verticalAlign=top;align=left;spacingLeft=30;fontColor=#232F3E;dashed=0;"
          value="&lt;b&gt;認証方式（変更前）&lt;/b&gt;&#xa;AD グループ SID で認可&#xa;例: S-1-5-21-XXXXXXXXXX&#xa;&#xa;課題: EOL後は継続運用困難" vertex="1">
          <mxGeometry height="110" width="190" x="80" y="470" as="geometry" />
        </mxCell>

        <!-- Before: Arrows -->
        <mxCell id="b-e1" edge="1" parent="1" source="b-user" target="b-cisco"
          style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#7F8C8D;strokeWidth=2;fontSize=10;fontStyle=1;fontColor=#555555;"
          value="VPN 接続">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="b-e2" edge="1" parent="1" source="b-cisco" target="b-ad"
          style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#7F8C8D;strokeWidth=2;fontSize=10;fontStyle=1;fontColor=#555555;"
          value="認証要求">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="b-e3" edge="1" parent="1" source="b-ad" target="b-internal"
          style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82B366;strokeWidth=2;fontSize=10;fontStyle=1;fontColor=#555555;"
          value="アクセス許可">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== MIGRATION ARROW (center divider) ===== -->
        <mxCell id="migration-arrow" edge="1" parent="1"
          style="html=1;strokeColor=#E74C3C;strokeWidth=4;fontSize=13;fontStyle=3;fontColor=#E74C3C;startArrow=none;endArrow=block;endFill=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          value="EOL 移行" source="before-panel" target="after-panel">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== AFTER PANEL ===== -->
        <mxCell id="after-panel" parent="1"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF5FB;strokeColor=#1A6A9F;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#1A6A9F;arcSize=2;spacingTop=8;spacingLeft=10;"
          value="【移行後】AWS Client VPN + SAML 2.0 認証" vertex="1">
          <mxGeometry height="720" width="1020" x="550" y="75" as="geometry" />
        </mxCell>

        <!-- ===== AFTER: User group ===== -->
        <mxCell id="a-users-group" parent="1"
          style="sketch=0;outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=11;fontStyle=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_corporate_data_center;strokeColor=#147EBA;fillColor=none;verticalAlign=top;align=left;spacingLeft=30;fontColor=#147EBA;dashed=0;"
          value="ユーザー端末" vertex="1">
          <mxGeometry height="550" width="140" x="565" y="110" as="geometry" />
        </mxCell>

        <!-- After: User (国内) -->
        <mxCell id="a-user-dom" parent="1"
          style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=1;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.user;"
          value="国内スタッフ&#xa;約95名" vertex="1">
          <mxGeometry height="60" width="60" x="607" y="175" as="geometry" />
        </mxCell>

        <!-- After: PC (国内) -->
        <mxCell id="a-pc-dom" parent="1"
          style="shape=mxgraph.networks2.icon;fillColor=#EDEDED;strokeColor=#000000;gradientColor=#5B6163;network2IconShadow=1;network2bgFillColor=none;labelPosition=center;verticalLabelPosition=bottom;align=center;verticalAlign=top;fontColor=#232F3E;fontSize=10;fontStyle=0;html=1;network2Icon=mxgraph.networks2.laptop;network2IconW=1;network2IconH=0.5734;"
          value="UDP 1194" vertex="1">
          <mxGeometry height="44" width="66" x="604" y="270" as="geometry" />
        </mxCell>

        <!-- After: User (海外) -->
        <mxCell id="a-user-ovs" parent="1"
          style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=1;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.user;"
          value="海外拠点（中国）&#xa;約20名" vertex="1">
          <mxGeometry height="60" width="60" x="607" y="405" as="geometry" />
        </mxCell>

        <!-- After: PC (海外) -->
        <mxCell id="a-pc-ovs" parent="1"
          style="shape=mxgraph.networks2.icon;fillColor=#EDEDED;strokeColor=#000000;gradientColor=#5B6163;network2IconShadow=1;network2bgFillColor=none;labelPosition=center;verticalLabelPosition=bottom;align=center;verticalAlign=top;fontColor=#232F3E;fontSize=10;fontStyle=0;html=1;network2Icon=mxgraph.networks2.laptop;network2IconW=1;network2IconH=0.5734;"
          value="TCP 443&#xa;（GFW 対策）" vertex="1">
          <mxGeometry height="44" width="66" x="604" y="500" as="geometry" />
        </mxCell>

        <!-- ===== AFTER: OneLogin (external IdP) ===== -->
        <mxCell id="a-onelogin" parent="1"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#E6B800;fontSize=11;fontStyle=1;verticalAlign=middle;"
          value="OneLogin (IdP)&#xa;SAML 2.0 + MFA&#xa;&#xa;メタデータ連携" vertex="1">
          <mxGeometry height="90" width="140" x="730" y="380" as="geometry" />
        </mxCell>

        <!-- ===== AFTER: AWS Cloud group ===== -->
        <mxCell id="a-aws-cloud" parent="1"
          style="sketch=0;outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=12;fontStyle=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_aws_cloud;strokeColor=#AAB7B8;fillColor=none;verticalAlign=top;align=left;spacingLeft=30;fontColor=#AAB7B8;dashed=0;"
          value="AWS Cloud (ap-northeast-1)" vertex="1">
          <mxGeometry height="550" width="580" x="890" y="110" as="geometry" />
        </mxCell>

        <!-- After: AWS Client VPN Endpoint -->
        <mxCell id="a-cvpn" parent="1"
          style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#8C4FFF;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.client_vpn;"
          value="AWS Client VPN&#xa;Endpoint" vertex="1">
          <mxGeometry height="60" width="60" x="960" y="230" as="geometry" />
        </mxCell>

        <!-- After: ACM -->
        <mxCell id="a-acm" parent="1"
          style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#DD344C;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.certificate_manager;"
          value="AWS Certificate&#xa;Manager (ACM)&#xa;サーバー証明書" vertex="1">
          <mxGeometry height="60" width="60" x="960" y="450" as="geometry" />
        </mxCell>

        <!-- After: IAM SAML Provider -->
        <mxCell id="a-iam" parent="1"
          style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#DD344C;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.role;"
          value="IAM SAML&#xa;プロバイダー&#xa;OneLogin-ClientVPN" vertex="1">
          <mxGeometry height="60" width="60" x="1120" y="230" as="geometry" />
        </mxCell>

        <!-- After: CloudWatch Logs -->
        <mxCell id="a-cw" parent="1"
          style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#E7157B;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudwatch;"
          value="CloudWatch Logs&#xa;接続監査ログ&#xa;/aws/clientvpn/*" vertex="1">
          <mxGeometry height="60" width="60" x="1310" y="230" as="geometry" />
        </mxCell>

        <!-- After: Authorization Rules note -->
        <mxCell id="a-authrules" parent="1"
          style="sketch=0;outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=10;fontStyle=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_note;strokeColor=#DD344C;fillColor=#FDEDEC;verticalAlign=top;align=left;spacingLeft=30;fontColor=#232F3E;dashed=0;"
          value="&lt;b&gt;認可ルール（グループ別 CIDR）&lt;/b&gt;&#xa;管理者: 全拠点ネットワーク&#xa;一般ユーザー: 業務システムのみ&#xa;VendorA: SAP 関連 (10.200.1.0/24)&#xa;VendorB: Web トランジット&#xa;&#xa;アクセスグループID = OneLogin ロール名&#xa;（完全一致・大文字小文字区別）" vertex="1">
          <mxGeometry height="170" width="220" x="1090" y="420" as="geometry" />
        </mxCell>

        <!-- ===== AFTER: Internal Systems ===== -->
        <mxCell id="a-sys-group" parent="1"
          style="sketch=0;outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=11;fontStyle=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_corporate_data_center;strokeColor=#147EBA;fillColor=none;verticalAlign=top;align=left;spacingLeft=30;fontColor=#147EBA;dashed=0;"
          value="社内ネットワーク（FENICS 網）" vertex="1">
          <mxGeometry height="490" width="150" x="1490" y="110" as="geometry" />
        </mxCell>

        <mxCell id="a-sys1" parent="1"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;verticalAlign=middle;"
          value="社内システム A" vertex="1">
          <mxGeometry height="40" width="110" x="1510" y="185" as="geometry" />
        </mxCell>

        <mxCell id="a-sys2" parent="1"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;verticalAlign=middle;"
          value="社内システム B" vertex="1">
          <mxGeometry height="40" width="110" x="1510" y="245" as="geometry" />
        </mxCell>

        <mxCell id="a-sys3" parent="1"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;verticalAlign=middle;"
          value="SAP 関連&#xa;(VendorA のみ)" vertex="1">
          <mxGeometry height="50" width="110" x="1510" y="305" as="geometry" />
        </mxCell>

        <mxCell id="a-sys4" parent="1"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;verticalAlign=middle;"
          value="管理 DB&#xa;(管理者のみ)" vertex="1">
          <mxGeometry height="50" width="110" x="1510" y="375" as="geometry" />
        </mxCell>

        <!-- ===== AFTER: SAML flow note ===== -->
        <mxCell id="a-saml-note" parent="1"
          style="sketch=0;outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=10;fontStyle=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_note;strokeColor=#8C4FFF;fillColor=#F3EEFF;verticalAlign=top;align=left;spacingLeft=30;fontColor=#232F3E;dashed=0;"
          value="&lt;b&gt;SAML 認証フロー&lt;/b&gt;&#xa;① VPN 接続 → ブラウザ自動起動&#xa;② OneLogin 画面 → ID/PW + MFA&#xa;③ SAMLアサーション → IAM に送信&#xa;④ memberOf 属性で認可判定&#xa;⑤ 接続許可 → VPN トンネル確立" vertex="1">
          <mxGeometry height="130" width="200" x="730" y="600" as="geometry" />
        </mxCell>

        <!-- ===== AFTER: ARROWS ===== -->

        <!-- ① 国内ユーザー → Client VPN -->
        <mxCell id="a-e1" edge="1" parent="1" source="a-pc-dom" target="a-cvpn"
          style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#8C4FFF;strokeWidth=2;fontSize=10;fontStyle=1;fontColor=#8C4FFF;"
          value="① VPN 接続">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ① 海外ユーザー → Client VPN -->
        <mxCell id="a-e2" edge="1" parent="1" source="a-pc-ovs" target="a-cvpn"
          style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#8C4FFF;strokeWidth=2;fontSize=10;fontStyle=0;fontColor=#8C4FFF;"
          value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ② Client VPN → OneLogin (SAML redirect) -->
        <mxCell id="a-e3" edge="1" parent="1" source="a-cvpn" target="a-onelogin"
          style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#E6B800;strokeWidth=2;fontSize=10;fontStyle=1;fontColor=#9B7E00;dashed=1;"
          value="② SAML&#xa;リダイレクト">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ③ OneLogin → IAM SAML Provider -->
        <mxCell id="a-e4" edge="1" parent="1" source="a-onelogin" target="a-iam"
          style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#DD344C;strokeWidth=2;fontSize=10;fontStyle=1;fontColor=#DD344C;"
          value="③ SAML アサーション&#xa;(memberOf 属性)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ④ IAM → Auth Rules -->
        <mxCell id="a-e5" edge="1" parent="1" source="a-iam" target="a-authrules"
          style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#DD344C;strokeWidth=2;fontSize=10;fontStyle=1;fontColor=#DD344C;dashed=1;"
          value="④ ロール名で&#xa;認可判定">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ⑤ Auth Rules → Internal Systems -->
        <mxCell id="a-e6" edge="1" parent="1" source="a-authrules" target="a-sys1"
          style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#147EBA;strokeWidth=2;fontSize=10;fontStyle=1;fontColor=#147EBA;"
          value="⑤ アクセス許可&#xa;（CIDR 制限）">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ACM → Client VPN (cert, dashed) -->
        <mxCell id="a-e7" edge="1" parent="1" source="a-acm" target="a-cvpn"
          style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#DD344C;strokeWidth=1;fontSize=10;fontStyle=0;fontColor=#DD344C;dashed=1;"
          value="サーバー証明書">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Client VPN → CloudWatch Logs (dashed) -->
        <mxCell id="a-e8" edge="1" parent="1" source="a-cvpn" target="a-cw"
          style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#E7157B;strokeWidth=1;fontSize=10;fontStyle=0;fontColor=#E7157B;dashed=1;"
          value="接続ログ出力">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
